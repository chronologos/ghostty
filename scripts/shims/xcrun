#!/usr/bin/env bash
# Workaround for ziglang/zig#31658: zig 0.15.2's MachO linker can't match
# arm64e-only libSystem.tbd in the Xcode 26.4 SDK. Redirect zig's SDK probe
# to a 15.4 SDK whose tbd still lists arm64-macos. Remove once zig ships
# the fix from PR #31673.
case " $* " in
  *" --sdk macosx "*|*" -sdk macosx "*)
    for a in "$@"; do
      if [[ "$a" == "--show-sdk-path" || "$a" == "-show-sdk-path" ]]; then
        echo "/Library/Developer/CommandLineTools/SDKs/MacOSX15.4.sdk"
        exit 0
      fi
    done
    ;;
esac
exec /usr/bin/xcrun "$@"
